[Unit]
Description=Trading Agent Managed Runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=trader
WorkingDirectory=/opt/trading-agent
ExecStart=/opt/trading-agent/.venv/bin/python /opt/trading-agent/managed_runner.py
Restart=always
RestartSec=10
TimeoutStopSec=30
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
