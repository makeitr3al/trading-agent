# Copy to /config/packages/trading_agent.yaml
# This package contains all Trading Agent helpers, sensors, shell commands,
# scripts, and the daily scheduling automation for the HAOS add-on setup.
#
# Set `input_text.trading_agent_notify_action` to your mobile notify action,
# for example: notify.mobile_app_dein_iphone

input_select:
  trading_agent_mode:
    name: Trading Agent Modus
    options:
      - Scharf
      - Preflight-Test
      - Beta-Write-Test
    initial: Scharf
    icon: mdi:target
  trading_agent_environment:
    name: Trading Agent Umgebung
    options:
      - beta
      - prod
    initial: beta
    icon: mdi:server-outline
  trading_agent_journal_entry_type:
    name: Trading Agent Journal Typ
    options:
      - Alle
      - cycle
      - order
      - trade
    initial: Alle
    icon: mdi:filter-variant

input_number:
  trading_agent_leverage:
    name: Trading Agent Leverage
    min: 1
    max: 20
    step: 1
    mode: box
    initial: 1
    icon: mdi:chart-line

input_text:
  trading_agent_markets:
    name: Trading Agent Maerkte
    initial: BTC/USDC:BTC,ETH/USDC:ETH,SOL/USDC:SOL
    max: 255
    icon: mdi:format-list-bulleted
  trading_agent_addon_slug:
    name: Trading Agent Add-on Slug
    initial: trading_agent
    max: 100
    icon: mdi:puzzle
  trading_agent_notify_action:
    name: Trading Agent Notify Aktion
    initial: notify.mobile_app_dein_geraet
    max: 100
    icon: mdi:cellphone-message
  trading_agent_last_notified_run_id:
    name: Trading Agent Letzte Benachrichtigung
    initial: ""
    max: 100
    icon: mdi:history
  trading_agent_journal_symbol_filter:
    name: Trading Agent Journal Marktfilter
    initial: ""
    max: 40
    icon: mdi:currency-usd
  trading_agent_journal_text_filter:
    name: Trading Agent Journal Textfilter
    initial: ""
    max: 120
    icon: mdi:text-search

input_boolean:
  trading_agent_scheduling_aktiv:
    name: Trading Agent Scheduling aktiv
    initial: false
    icon: mdi:calendar-clock
  trading_agent_push_aktiv:
    name: Trading Agent Push aktiv
    initial: false
    icon: mdi:bell-ring-outline

input_datetime:
  trading_agent_schedule_time:
    name: Trading Agent Ausfuehrungszeit
    has_date: false
    has_time: true

command_line:
  - sensor:
      name: Trading Agent Operator Config
      unique_id: trading_agent_operator_config
      command: >-
        cat /share/trading-agent-data/operator_config.json 2>/dev/null || echo '{"mode":"unknown","environment":null,"leverage":null,"markets":null,"scheduling_enabled":null,"schedule_time":null}'
      value_template: "{{ value_json.mode | default('unknown') }}"
      json_attributes:
        - environment
        - leverage
        - markets
        - scheduling_enabled
        - schedule_time
      scan_interval: 30
  - sensor:
      name: Trading Agent Tests
      unique_id: trading_agent_tests
      command: >-
        cat /share/trading-agent-data/test_suite_status.json 2>/dev/null || echo '{"runner_state":"unknown","suite":null,"success":null,"return_code":null,"last_error":null,"output_tail":[]}'
      value_template: "{{ value_json.runner_state | default('unknown') }}"
      json_attributes:
        - suite
        - started_at
        - finished_at
        - success
        - return_code
        - log_path
        - output_tail
        - last_error
      scan_interval: 30
  - sensor:
      name: Trading Agent Journal
      unique_id: trading_agent_journal
      command: >-
        cat /share/trading-agent-data/journal_snapshot.json 2>/dev/null || echo '{"latest_cycle_action":"unknown","journal_path":null,"exists":false,"entry_count":0,"cycle_count":0,"order_count":0,"trade_count":0,"latest_entry_timestamp":null,"latest_cycle_skipped_reason":null,"latest_order_status":null,"latest_trade_status":null,"latest_trade_pnl":null,"recent_entries":[]}'
      value_template: "{{ value_json.latest_cycle_action | default('unknown') }}"
      json_attributes:
        - journal_path
        - exists
        - latest_entry_timestamp
        - latest_cycle_skipped_reason
        - latest_order_status
        - latest_trade_status
        - latest_trade_pnl
        - entry_count
        - cycle_count
        - order_count
        - trade_count
        - recent_entries
      scan_interval: 60
  - sensor:
      name: Trading Agent Run Summary
      unique_id: trading_agent_run_summary
      command: >-
        cat /share/trading-agent-data/run_summary.json 2>/dev/null || echo '{"run_id":"unknown","mode":null,"environment":null,"started_at":null,"finished_at":null,"success":null,"exit_code":null,"suite":null,"entry_count":0,"cycle_count":0,"order_count":0,"trade_count":0,"symbols":[],"latest_symbol":null,"latest_outcome":null,"title":null,"notification_title":null,"notification_message":null,"summary_lines":[]}'
      value_template: "{{ value_json.run_id | default('unknown') }}"
      json_attributes:
        - mode
        - environment
        - started_at
        - finished_at
        - success
        - exit_code
        - suite
        - entry_count
        - cycle_count
        - order_count
        - trade_count
        - symbols
        - latest_symbol
        - latest_outcome
        - title
        - notification_title
        - notification_message
        - summary_lines
      scan_interval: 30

shell_command:
  trading_agent_save_operator_config_haos: >-
    python3 -c "import json, sys; from pathlib import Path; path = Path('/share/trading-agent-data/operator_config.json'); path.parent.mkdir(parents=True, exist_ok=True); payload = {'mode': sys.argv[1], 'environment': sys.argv[2], 'leverage': int(sys.argv[3]), 'markets': sys.argv[4], 'scheduling_enabled': sys.argv[5].lower() == 'true', 'schedule_time': sys.argv[6]}; path.write_text(json.dumps(payload, ensure_ascii=True) + '\n', encoding='utf-8')" "{{ mode }}" "{{ environment }}" "{{ leverage }}" "{{ markets }}" "{{ scheduling_enabled }}" "{{ schedule_time }}"
  trading_agent_reset_operator_config_haos: >-
    python3 -c "import json; from pathlib import Path; path = Path('/share/trading-agent-data/operator_config.json'); path.parent.mkdir(parents=True, exist_ok=True); payload = {'mode': 'scharf', 'environment': 'beta', 'leverage': 1, 'markets': 'BTC/USDC:BTC,ETH/USDC:ETH,SOL/USDC:SOL', 'scheduling_enabled': False, 'schedule_time': '07:00'}; path.write_text(json.dumps(payload, ensure_ascii=True) + '\n', encoding='utf-8')"

script:
  trading_agent_save_current_config_haos:
    alias: Trading Agent Konfiguration speichern
    mode: single
    sequence:
      - variables:
          selected_mode: >-
            {% if states('input_select.trading_agent_mode') == 'Preflight-Test' %}
              preflight
            {% elif states('input_select.trading_agent_mode') == 'Beta-Write-Test' %}
              beta_write
            {% else %}
              scharf
            {% endif %}
      - action: shell_command.trading_agent_save_operator_config_haos
        data:
          mode: "{{ selected_mode | trim }}"
          environment: "{{ states('input_select.trading_agent_environment') }}"
          leverage: "{{ states('input_number.trading_agent_leverage') | int }}"
          markets: "{{ states('input_text.trading_agent_markets') }}"
          scheduling_enabled: "{{ 'true' if is_state('input_boolean.trading_agent_scheduling_aktiv', 'on') else 'false' }}"
          schedule_time: "{{ states('input_datetime.trading_agent_schedule_time')[:5] }}"

  trading_agent_jetzt_ausfuehren_haos:
    alias: Trading Agent Aktuellen Modus ausfuehren
    mode: single
    sequence:
      - action: script.trading_agent_save_current_config_haos
      - action: hassio.addon_start
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_preflight_test_haos:
    alias: Trading Agent Preflight-Test ausfuehren
    mode: single
    sequence:
      - action: shell_command.trading_agent_save_operator_config_haos
        data:
          mode: "preflight"
          environment: "{{ states('input_select.trading_agent_environment') }}"
          leverage: "{{ states('input_number.trading_agent_leverage') | int }}"
          markets: "{{ states('input_text.trading_agent_markets') }}"
          scheduling_enabled: "{{ 'true' if is_state('input_boolean.trading_agent_scheduling_aktiv', 'on') else 'false' }}"
          schedule_time: "{{ states('input_datetime.trading_agent_schedule_time')[:5] }}"
      - action: hassio.addon_start
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_beta_write_test_haos:
    alias: Trading Agent Beta-Write-Test ausfuehren
    mode: single
    sequence:
      - action: shell_command.trading_agent_save_operator_config_haos
        data:
          mode: "beta_write"
          environment: "{{ states('input_select.trading_agent_environment') }}"
          leverage: "{{ states('input_number.trading_agent_leverage') | int }}"
          markets: "{{ states('input_text.trading_agent_markets') }}"
          scheduling_enabled: "{{ 'true' if is_state('input_boolean.trading_agent_scheduling_aktiv', 'on') else 'false' }}"
          schedule_time: "{{ states('input_datetime.trading_agent_schedule_time')[:5] }}"
      - action: hassio.addon_start
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_scharf_lauf_haos:
    alias: Trading Agent Scharf-Lauf ausfuehren
    mode: single
    sequence:
      - action: shell_command.trading_agent_save_operator_config_haos
        data:
          mode: "scharf"
          environment: "{{ states('input_select.trading_agent_environment') }}"
          leverage: "{{ states('input_number.trading_agent_leverage') | int }}"
          markets: "{{ states('input_text.trading_agent_markets') }}"
          scheduling_enabled: "{{ 'true' if is_state('input_boolean.trading_agent_scheduling_aktiv', 'on') else 'false' }}"
          schedule_time: "{{ states('input_datetime.trading_agent_schedule_time')[:5] }}"
      - action: hassio.addon_start
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_stop_haos:
    alias: Trading Agent Stopp
    mode: single
    sequence:
      - action: hassio.addon_stop
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_neustart_haos:
    alias: Trading Agent Neustart
    mode: single
    sequence:
      - action: script.trading_agent_save_current_config_haos
      - action: hassio.addon_restart
        data:
          addon: "{{ states('input_text.trading_agent_addon_slug') }}"

  trading_agent_reset_operator_config_haos:
    alias: Trading Agent Konfiguration zuruecksetzen
    mode: single
    sequence:
      - action: shell_command.trading_agent_reset_operator_config_haos

automation:
  - alias: Trading Agent Geplanter Scharf-Lauf
    id: trading_agent_geplanter_scharf_lauf
    mode: single
    triggers:
      - trigger: time
        at: input_datetime.trading_agent_schedule_time
    conditions:
      - condition: state
        entity_id: input_boolean.trading_agent_scheduling_aktiv
        state: "on"
    actions:
      - action: script.trading_agent_scharf_lauf_haos

  - alias: Trading Agent Push nach Lauf
    id: trading_agent_push_nach_lauf
    mode: single
    triggers:
      - trigger: state
        entity_id: sensor.trading_agent_run_summary
    conditions:
      - condition: state
        entity_id: input_boolean.trading_agent_push_aktiv
        state: "on"
      - condition: template
        value_template: >-
          {% set run_id = states('sensor.trading_agent_run_summary') %}
          {{ run_id not in [None, '', 'unknown', 'unavailable'] and run_id != states('input_text.trading_agent_last_notified_run_id') }}
    actions:
      - choose:
          - conditions:
              - condition: template
                value_template: "{{ states('input_text.trading_agent_notify_action') | trim != '' }}"
            sequence:
              - action: "{{ states('input_text.trading_agent_notify_action') | trim }}"
                data:
                  title: "{{ state_attr('sensor.trading_agent_run_summary', 'notification_title') or 'Trading Agent' }}"
                  message: "{{ state_attr('sensor.trading_agent_run_summary', 'notification_message') or 'Trading Agent Lauf abgeschlossen.' }}"
                  data:
                    tag: trading-agent-last-run
                    clickAction: /trading-agent
                    url: /trading-agent
        default:
          - action: persistent_notification.create
            data:
              title: "{{ state_attr('sensor.trading_agent_run_summary', 'notification_title') or 'Trading Agent' }}"
              message: >-
                {% for line in state_attr('sensor.trading_agent_run_summary', 'summary_lines') or [] %}
                - {{ line }}
                {% endfor %}
      - action: input_text.set_value
        target:
          entity_id: input_text.trading_agent_last_notified_run_id
        data:
          value: "{{ states('sensor.trading_agent_run_summary') }}"
