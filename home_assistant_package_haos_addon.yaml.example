# Copy to /config/packages/trading_agent.yaml
# This package contains Trading Agent helpers, sensors, and shell commands
# for the HAOS add-on setup.
#
# Copy the companion files:
# - home_assistant_panel_haos_addon.yaml.example -> /config/configuration.yaml
# - home_assistant_scripts_haos_addon.yaml.example -> /config/scripts.yaml
# - home_assistant_automations_haos_addon.yaml.example -> /config/automations.yaml

input_select:
  trading_agent_mode:
    name: Trading Agent Modus
    options:
      - Scharf
      - Preflight-Test
      - Beta-Write-Test
    initial: Scharf
    icon: mdi:target
  trading_agent_environment:
    name: Trading Agent Umgebung
    options:
      - beta
      - prod
    initial: beta
    icon: mdi:server-outline

input_number:
  trading_agent_leverage:
    name: Trading Agent Leverage
    min: 1
    max: 20
    step: 1
    mode: box
    initial: 1
    icon: mdi:chart-line

input_text:
  trading_agent_markets:
    name: Trading Agent Maerkte
    initial: BTC/USDC:BTC,ETH/USDC:ETH,SOL/USDC:SOL
    max: 255
    icon: mdi:format-list-bulleted
  trading_agent_addon_slug:
    name: Trading Agent Add-on Slug
    initial: trading_agent
    max: 100
    icon: mdi:puzzle
  trading_agent_last_notified_run_id:
    name: Trading Agent Letzte Benachrichtigung
    initial: ""
    max: 100
    icon: mdi:history

input_boolean:
  trading_agent_scheduling_aktiv:
    name: Trading Agent Scheduling aktiv
    initial: false
    icon: mdi:calendar-clock
  trading_agent_push_aktiv:
    name: Trading Agent Push aktiv
    initial: false
    icon: mdi:bell-ring-outline

input_datetime:
  trading_agent_schedule_time:
    name: Trading Agent Ausfuehrungszeit
    has_date: false
    has_time: true

command_line:
  - sensor:
      name: Trading Agent Operator Config
      unique_id: trading_agent_operator_config
      command: >-
        cat /share/trading-agent-data/operator_config.json 2>/dev/null || echo '{"mode":"unknown","environment":null,"leverage":null,"markets":null,"scheduling_enabled":null,"schedule_time":null}'
      value_template: "{{ value_json.mode | default('unknown') }}"
      json_attributes:
        - environment
        - leverage
        - markets
        - scheduling_enabled
        - schedule_time
      scan_interval: 30
  - sensor:
      name: Trading Agent Tests
      unique_id: trading_agent_tests
      command: >-
        cat /share/trading-agent-data/test_suite_status.json 2>/dev/null || echo '{"runner_state":"unknown","suite":null,"success":null,"return_code":null,"last_error":null,"output_tail":[]}'
      value_template: "{{ value_json.runner_state | default('unknown') }}"
      json_attributes:
        - suite
        - started_at
        - finished_at
        - success
        - return_code
        - log_path
        - output_tail
        - last_error
      scan_interval: 30
  - sensor:
      name: Trading Agent Journal
      unique_id: trading_agent_journal
      command: >-
        cat /share/trading-agent-data/journal_snapshot.json 2>/dev/null || echo '{"latest_cycle_action":"unknown","journal_path":null,"exists":false,"entry_count":0,"cycle_count":0,"order_count":0,"trade_count":0,"latest_entry_timestamp":null,"latest_cycle_skipped_reason":null,"latest_order_status":null,"latest_trade_status":null,"latest_trade_pnl":null,"recent_entries":[]}'
      value_template: "{{ value_json.latest_cycle_action | default('unknown') }}"
      json_attributes:
        - journal_path
        - exists
        - latest_entry_timestamp
        - latest_cycle_skipped_reason
        - latest_order_status
        - latest_trade_status
        - latest_trade_pnl
        - entry_count
        - cycle_count
        - order_count
        - trade_count
        - recent_entries
      scan_interval: 60
  - sensor:
      name: Trading Agent Run Summary
      unique_id: trading_agent_run_summary
      command: >-
        cat /share/trading-agent-data/run_summary.json 2>/dev/null || echo '{"run_id":"unknown","mode":null,"environment":null,"started_at":null,"finished_at":null,"success":null,"exit_code":null,"suite":null,"entry_count":0,"cycle_count":0,"order_count":0,"trade_count":0,"symbols":[],"latest_symbol":null,"latest_outcome":null,"title":null,"notification_title":null,"notification_message":null,"summary_lines":[]}'
      value_template: "{{ value_json.run_id | default('unknown') }}"
      json_attributes:
        - mode
        - environment
        - started_at
        - finished_at
        - success
        - exit_code
        - suite
        - entry_count
        - cycle_count
        - order_count
        - trade_count
        - symbols
        - latest_symbol
        - latest_outcome
        - title
        - notification_title
        - notification_message
        - summary_lines
      scan_interval: 30
  - sensor:
      name: Trading Agent Live Status
      unique_id: trading_agent_live_status
      command: >-
        cat /share/trading-agent-data/live_status.json 2>/dev/null || echo '{"updated_at":null,"environment":null,"account_unrealized_pnl":null,"account_open_positions_count":0,"websocket_connected":false,"source":"unknown","last_error":null}'
      value_template: "{{ value_json.source | default('unknown') }}"
      json_attributes:
        - updated_at
        - environment
        - account_unrealized_pnl
        - account_open_positions_count
        - websocket_connected
        - source
        - last_error
      scan_interval: 30

shell_command:
  trading_agent_save_operator_config_haos: >-
    python3 -c "import json, sys; from pathlib import Path; path = Path('/share/trading-agent-data/operator_config.json'); path.parent.mkdir(parents=True, exist_ok=True); payload = {'mode': sys.argv[1], 'environment': sys.argv[2], 'leverage': int(sys.argv[3]), 'markets': sys.argv[4], 'scheduling_enabled': sys.argv[5].lower() == 'true', 'schedule_time': sys.argv[6]}; path.write_text(json.dumps(payload, ensure_ascii=True) + '\n', encoding='utf-8')" "{{ mode }}" "{{ environment }}" "{{ leverage }}" "{{ markets }}" "{{ scheduling_enabled }}" "{{ schedule_time }}"
  trading_agent_reset_operator_config_haos: >-
    python3 -c "import json; from pathlib import Path; path = Path('/share/trading-agent-data/operator_config.json'); path.parent.mkdir(parents=True, exist_ok=True); payload = {'mode': 'scharf', 'environment': 'beta', 'leverage': 1, 'markets': 'BTC/USDC:BTC,ETH/USDC:ETH,SOL/USDC:SOL', 'scheduling_enabled': False, 'schedule_time': '07:00'}; path.write_text(json.dumps(payload, ensure_ascii=True) + '\n', encoding='utf-8')"
  trading_agent_sync_panel_assets_haos: >-
    sh -c "mkdir -p /config/www/trading-agent && if [ -f /share/trading-agent-data/journal_table.json ]; then cp /share/trading-agent-data/journal_table.json /config/www/trading-agent/journal_table.json; else printf '%s' '{\"generated_at\":null,\"latest_entry_timestamp\":null,\"journal_path\":null,\"exists\":false,\"entry_count_total\":0,\"scan_rows\":[],\"trade_rows\":[],\"filter_options\":{\"symbols\":[],\"environments\":[],\"decision_actions\":[],\"scan_signals\":[],\"entry_types\":[],\"trade_statuses\":[],\"directions\":[],\"signal_sources\":[]},\"warnings\":[\"journal_table.json fehlt in /share/trading-agent-data\"]}' > /config/www/trading-agent/journal_table.json; fi && if [ -f /share/trading-agent-data/live_status.json ]; then cp /share/trading-agent-data/live_status.json /config/www/trading-agent/live_status.json; else printf '%s' '{\"updated_at\":null,\"environment\":null,\"account_unrealized_pnl\":null,\"account_open_positions_count\":0,\"websocket_connected\":false,\"source\":\"unknown\",\"last_error\":null}' > /config/www/trading-agent/live_status.json; fi"
