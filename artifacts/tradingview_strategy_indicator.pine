//@version=6
indicator("Propr Strategy Verifier", shorttitle="PR Verify", overlay=true, max_labels_count=500)

bollingerPeriod = input.int(12, "Bollinger Period", minval=1)
bollingerStdDev = input.float(2.0, "Bollinger Std Dev", minval=0.1, step=0.1)
macdFastPeriod = input.int(12, "MACD Fast Period", minval=1)
macdSlowPeriod = input.int(26, "MACD Slow Period", minval=1)
macdSignalPeriod = input.int(9, "MACD Signal Period", minval=1)
insideBufferPct = input.float(0.20, "Inside Buffer Pct", minval=0.0, step=0.01)
outsideBufferPct = input.float(0.20, "Outside Buffer Pct", minval=0.0, step=0.01)
outsideBandSweetSpot = input.float(0.0, "Outside Band Sweet Spot", minval=0.0, step=0.0001)
buySpread = input.float(0.0, "Buy Spread", minval=0.0, step=0.0001)
minBandwidthAvgPeriod = input.int(30, "Min Bandwidth Avg Period", minval=1)
minBandwidthRatio = input.float(0.70, "Min Bandwidth Ratio", minval=0.0, step=0.01)
maxBarsSinceRegimeStartForTrendSignal = input.int(6, "Max Bars Since Regime Start For Trend", minval=1)
trendTpRr = input.float(2.0, "Trend TP RR", minval=0.1, step=0.1)
showRegimeBackground = input.bool(true, "Show Regime Background")
colorBarsByRegime = input.bool(false, "Color Bars By Regime")
showSignalMarkers = input.bool(true, "Show Signal Markers")
showPendingMarkers = input.bool(true, "Show Pending Markers")
showFillMarkers = input.bool(true, "Show Fill Markers")
showSweetSpotMarkers = input.bool(true, "Show Sweet Spot Markers")
showTradeManagementMarkers = input.bool(true, "Show Trade Management Markers")
showSignalLevels = input.bool(true, "Show Signal Levels")
showStatusTable = input.bool(true, "Show Status Table")

bbMiddle = ta.sma(close, bollingerPeriod)
float bbSquaredDeviationSum = 0.0
if not na(bbMiddle) and bollingerPeriod > 1
    bbSquaredDeviationSum := 0.0
    for i = 0 to bollingerPeriod - 1
        bbSquaredDeviationSum += math.pow(close[i] - bbMiddle, 2)
bbStdDev = not na(bbMiddle) and bollingerPeriod > 1 ? math.sqrt(bbSquaredDeviationSum / (bollingerPeriod - 1)) : na
bbUpper = bbMiddle + bollingerStdDev * bbStdDev
bbLower = bbMiddle - bollingerStdDev * bbStdDev

[macdLine, macdSignalLine, macdHist] = ta.macd(close, macdFastPeriod, macdSlowPeriod, macdSignalPeriod)

regimeBullish = macdLine > 0 and macdLine > macdSignalLine
regimeBearish = macdLine < 0 and macdLine < macdSignalLine
regimeNeutral = not regimeBullish and not regimeBearish
regimeName = regimeBullish ? "bullish" : regimeBearish ? "bearish" : "neutral"

var int barsSinceRegimeStart = 0
sameRegimeAsPrevious = regimeBullish == regimeBullish[1] and regimeBearish == regimeBearish[1] and regimeNeutral == regimeNeutral[1]
regimeChanged = not barstate.isfirst and not sameRegimeAsPrevious
barsSinceRegimeStart := barstate.isfirst ? 1 : sameRegimeAsPrevious ? nz(barsSinceRegimeStart[1]) + 1 : 1

hasBollingerData = not na(bbUpper) and not na(bbMiddle) and not na(bbLower)
upperHalfBandwidth = bbUpper - bbMiddle
lowerHalfBandwidth = bbMiddle - bbLower
relevantHalfBandwidth = regimeBearish ? lowerHalfBandwidth : upperHalfBandwidth
avgRelevantHalfBandwidth = ta.sma(relevantHalfBandwidth, minBandwidthAvgPeriod)
avgUpperHalfBandwidth = ta.sma(upperHalfBandwidth, minBandwidthAvgPeriod)
avgLowerHalfBandwidth = ta.sma(lowerHalfBandwidth, minBandwidthAvgPeriod)
hasSufficientBandwidth = hasBollingerData and not na(avgRelevantHalfBandwidth) and relevantHalfBandwidth >= minBandwidthRatio * avgRelevantHalfBandwidth
candleInTrendDirection = regimeBullish ? close > open : regimeBearish ? close < open : false
closeInRelevantBandHalf = regimeBullish ? (hasBollingerData and close >= bbMiddle and close <= bbUpper) : regimeBearish ? (hasBollingerData and close >= bbLower and close <= bbMiddle) : false
requiredInsideDistance = insideBufferPct * relevantHalfBandwidth
requiredOutsideDistance = outsideBufferPct * relevantHalfBandwidth
neutralRequiredOutsideDistanceShort = outsideBufferPct * upperHalfBandwidth
neutralRequiredOutsideDistanceLong = outsideBufferPct * lowerHalfBandwidth
closeDeepInsideBands = regimeBullish ? (closeInRelevantBandHalf and (bbUpper - close) >= requiredInsideDistance) : regimeBearish ? (closeInRelevantBandHalf and (close - bbLower) >= requiredInsideDistance) : false
closeDeepOutsideBands = regimeBullish ? (hasBollingerData and close >= bbUpper + requiredOutsideDistance) : regimeBearish ? (hasBollingerData and close <= bbLower - requiredOutsideDistance) : false
neutralCloseDeepOutsideShort = hasBollingerData and close >= bbUpper + neutralRequiredOutsideDistanceShort
neutralCloseDeepOutsideLong = hasBollingerData and close <= bbLower - neutralRequiredOutsideDistanceLong
countertrendCloseDeepOutside = regimeNeutral ? (neutralCloseDeepOutsideShort or neutralCloseDeepOutsideLong) : closeDeepOutsideBands
countertrendHasSufficientBandwidth = regimeNeutral ? (countertrendSignalType == "COUNTERTREND_SHORT" ? (hasBollingerData and not na(avgUpperHalfBandwidth) and upperHalfBandwidth >= minBandwidthRatio * avgUpperHalfBandwidth) : (hasBollingerData and not na(avgLowerHalfBandwidth) and lowerHalfBandwidth >= minBandwidthRatio * avgLowerHalfBandwidth)) : hasSufficientBandwidth
closeInOuterBandSweetSpot = regimeBullish ? (hasBollingerData and close >= bbUpper - outsideBandSweetSpot) : regimeBearish ? (hasBollingerData and close <= bbLower + outsideBandSweetSpot) : false
closeOutsideTrigger = closeDeepOutsideBands or closeInOuterBandSweetSpot
outsideTriggerReason = closeDeepOutsideBands ? "outside buffer" : closeInOuterBandSweetSpot ? "sweet spot" : "n/a"

trendSignalType = regimeBullish ? "TREND_LONG" : regimeBearish ? "TREND_SHORT" : "TREND_LONG"
neutralCountertrendSignalType = neutralCloseDeepOutsideShort ? "COUNTERTREND_SHORT" : neutralCloseDeepOutsideLong ? "COUNTERTREND_LONG" : hasBollingerData and close >= bbMiddle ? "COUNTERTREND_SHORT" : "COUNTERTREND_LONG"
countertrendSignalType = regimeBullish ? "COUNTERTREND_SHORT" : regimeBearish ? "COUNTERTREND_LONG" : neutralCountertrendSignalType

string trendReason = ""
bool trendValid = false
float trendEntry = na
float trendStop = na
float trendTakeProfit = na

if not hasBollingerData
    trendReason := "too few bars since data start"
else if regimeNeutral
    trendReason := "neutral regime"
else if barsSinceRegimeStart > maxBarsSinceRegimeStartForTrendSignal
    trendReason := "regime too old"
else if not candleInTrendDirection
    trendReason := "candle not in trend direction"
else if not closeDeepInsideBands
    trendReason := "close not deep inside bands"
else if not hasSufficientBandwidth
    trendReason := "insufficient bandwidth"
else
    trendValid := true
    trendReason := "trend signal detected"
    if regimeBullish
        trendEntry := bbUpper + buySpread
        trendStop := bbMiddle + buySpread
        trendTakeProfit := trendEntry + trendTpRr * (trendEntry - trendStop)
    else
        trendEntry := bbLower
        trendStop := bbMiddle
        trendTakeProfit := trendEntry - trendTpRr * (trendStop - trendEntry)

string countertrendReason = ""
bool countertrendValid = false
float countertrendEntry = na
float countertrendStop = na
float countertrendTakeProfit = na
string countertrendOrderType = "n/a"

if not hasBollingerData
    countertrendReason := "too few bars since data start"
else if not regimeNeutral and barsSinceRegimeStart != 1
    countertrendReason := "not first regime bar"
else if not countertrendCloseDeepOutside
    countertrendReason := "close not outside bands"
else if not countertrendHasSufficientBandwidth
    countertrendReason := "insufficient bandwidth"
else
    countertrendValid := true
    countertrendReason := "countertrend signal detected"
    if countertrendSignalType == "COUNTERTREND_SHORT"
        countertrendOrderType := "sell_limit"
        countertrendEntry := close
        countertrendStop := countertrendEntry + (countertrendEntry - bbMiddle)
        countertrendTakeProfit := bbMiddle
    else
        countertrendOrderType := "buy_limit"
        countertrendEntry := close + buySpread
        countertrendStop := (close - (bbMiddle - close)) + buySpread
        countertrendTakeProfit := bbMiddle + buySpread

trendOrderType = regimeBullish ? "buy_stop" : regimeBearish ? "sell_stop" : "n/a"
trendDirection = regimeBullish ? 1 : regimeBearish ? -1 : 0
countertrendDirection = countertrendSignalType == "COUNTERTREND_LONG" ? 1 : countertrendSignalType == "COUNTERTREND_SHORT" ? -1 : 0

var int simPendingDirection = 0
var string simPendingKind = "none"
var string simPendingOrderType = "none"
var float simPendingEntry = na
var float simPendingStop = na
var float simPendingTakeProfit = na

var int simActiveDirection = 0
var string simActiveKind = "none"
var float simActiveEntry = na
var float simActiveStop = na
var float simActiveTakeProfit = na
var bool simActiveBreakEven = false

var bool regimeConsumed = false
var bool countertrendLongConsumedInRegime = false
var bool countertrendShortConsumedInRegime = false

bool trendSignalMarker = false
bool countertrendSignalMarker = false
bool pendingPlacedMarker = false
bool pendingRefreshedMarker = false
bool pendingCancelledMarker = false
bool fillMarker = false
bool exitMarker = false
bool stopAdjustMarker = false
bool tpAdjustMarker = false
string cycleAction = "n/a"
string fillLabel = ""
string exitLabel = ""
string pendingLabel = ""

if countertrendValid
    bool countertrendConsumedForDirection = countertrendDirection == 1 ? countertrendLongConsumedInRegime : countertrendDirection == -1 ? countertrendShortConsumedInRegime : false
    if countertrendConsumedForDirection
        countertrendValid := false
        countertrendReason := "countertrend regime direction consumed"
        countertrendEntry := na
        countertrendStop := na
        countertrendTakeProfit := na

if regimeChanged
    regimeConsumed := false
    countertrendLongConsumedInRegime := false
    countertrendShortConsumedInRegime := false

if countertrendValid
    if countertrendDirection == 1
        countertrendLongConsumedInRegime := true
    else if countertrendDirection == -1
        countertrendShortConsumedInRegime := true

bool pendingWasFilled = false
string filledPendingKind = "none"
int filledPendingDirection = 0
float filledPendingEntry = na
float filledPendingStop = na
float filledPendingTakeProfit = na

if simPendingDirection != 0
    pendingFilledNow = simPendingOrderType == "buy_stop" ? high >= simPendingEntry : simPendingOrderType == "sell_stop" ? low <= simPendingEntry : simPendingOrderType == "buy_limit" ? low <= simPendingEntry : simPendingOrderType == "sell_limit" ? high >= simPendingEntry : false
    if pendingFilledNow
        pendingWasFilled := true
        filledPendingKind := simPendingKind
        filledPendingDirection := simPendingDirection
        filledPendingEntry := simPendingEntry
        filledPendingStop := simPendingStop
        filledPendingTakeProfit := simPendingTakeProfit
        simPendingDirection := 0
        simPendingKind := "none"
        simPendingOrderType := "none"
        simPendingEntry := na
        simPendingStop := na
        simPendingTakeProfit := na
        simActiveDirection := filledPendingDirection
        simActiveKind := filledPendingKind
        simActiveEntry := filledPendingEntry
        simActiveStop := filledPendingStop
        simActiveTakeProfit := filledPendingTakeProfit
        simActiveBreakEven := false
        fillMarker := true
        fillLabel := filledPendingKind == "trend" ? "Trend Fill" : "Counter Fill"
        cycleAction := fillLabel

activeTrendTrade = simActiveDirection != 0 and simActiveKind == "trend"
activeCountertrendTrade = simActiveDirection != 0 and simActiveKind == "countertrend"

if activeCountertrendTrade
    float managementMiddle = not na(bbMiddle[1]) ? bbMiddle[1] : bbMiddle
    if not na(managementMiddle)
        float updatedCounterTp = simActiveDirection == 1 ? managementMiddle + buySpread : managementMiddle
        if simActiveTakeProfit != updatedCounterTp
            tpAdjustMarker := true
        simActiveTakeProfit := updatedCounterTp

    bool counterCloseTriggered = simActiveDirection == 1 ? high >= bbMiddle : low <= bbMiddle
    if counterCloseTriggered
        simActiveDirection := 0
        simActiveKind := "none"
        simActiveEntry := na
        simActiveStop := na
        simActiveTakeProfit := na
        simActiveBreakEven := false
        exitMarker := true
        exitLabel := "Counter Exit"
        cycleAction := exitLabel

activeTrendTrade := simActiveDirection != 0 and simActiveKind == "trend"
if activeTrendTrade
    float tradeRelevantHalfBandwidth = simActiveDirection == 1 ? (bbUpper - bbMiddle) : (bbMiddle - bbLower)
    float tradeRequiredOutsideDistance = not na(tradeRelevantHalfBandwidth) ? outsideBufferPct * tradeRelevantHalfBandwidth : na
    bool tradeCloseDeepOutside = simActiveDirection == 1 ? (hasBollingerData and not na(tradeRequiredOutsideDistance) and close >= bbUpper + tradeRequiredOutsideDistance) : (hasBollingerData and not na(tradeRequiredOutsideDistance) and close <= bbLower - tradeRequiredOutsideDistance)
    bool tradeCloseInSweetSpot = simActiveDirection == 1 ? (hasBollingerData and close >= bbUpper - outsideBandSweetSpot) : (hasBollingerData and close <= bbLower + outsideBandSweetSpot)
    bool simulatedTrendExitTriggered = tradeCloseDeepOutside or tradeCloseInSweetSpot
    bool canTightenToLastClose = simActiveDirection == 1 ? (close > simActiveEntry and close > simActiveStop) : (close < simActiveEntry and close < simActiveStop)

    if simulatedTrendExitTriggered
        regimeConsumed := true
        if canTightenToLastClose
            simActiveStop := simActiveDirection == 1 ? math.max(simActiveStop, close) : math.min(simActiveStop, close)
            stopAdjustMarker := true
            cycleAction := "Trend Stop -> Last Close"
        else
            simActiveDirection := 0
            simActiveKind := "none"
            simActiveEntry := na
            simActiveStop := na
            simActiveTakeProfit := na
            simActiveBreakEven := false
            exitMarker := true
            exitLabel := "Trend Exit"
            cycleAction := exitLabel
    else
        if simActiveBreakEven
            simActiveStop := simActiveEntry
        else
            float currentRisk = simActiveDirection == 1 ? (simActiveEntry - simActiveStop) : (simActiveStop - simActiveEntry)
            float currentProfit = simActiveDirection == 1 ? (close - simActiveEntry) : (simActiveEntry - close)
            if currentRisk > 0 and currentProfit >= currentRisk
                simActiveStop := simActiveEntry
                simActiveBreakEven := true
                stopAdjustMarker := true
                cycleAction := "Trend Break-even"
            else
                float targetTrendStop = simActiveDirection == 1 ? bbMiddle + buySpread : bbMiddle
                float updatedTrendStop = simActiveDirection == 1 ? math.max(simActiveStop, targetTrendStop) : math.min(simActiveStop, targetTrendStop)
                if updatedTrendStop != simActiveStop
                    stopAdjustMarker := true
                    cycleAction := "Trend Trail"
                simActiveStop := updatedTrendStop

activeTradeExists = simActiveDirection != 0
pendingExists = simPendingDirection != 0
sameTrendPendingType = simPendingKind == "trend" and simPendingDirection == trendDirection and trendDirection != 0

trendSignalMarker := trendValid
countertrendSignalMarker := countertrendValid

if not activeTradeExists
    if countertrendValid
        newPendingDirection = countertrendDirection
        newPendingKind = "countertrend"
        newPendingOrderType = countertrendOrderType
        newPendingEntry = countertrendEntry
        newPendingStop = countertrendStop
        newPendingTakeProfit = countertrendTakeProfit
        if simPendingDirection != 0 and (simPendingEntry != newPendingEntry or simPendingStop != newPendingStop or simPendingTakeProfit != newPendingTakeProfit or simPendingKind != newPendingKind)
            pendingRefreshedMarker := true
            pendingLabel := "Counter Pending"
        else if simPendingDirection == 0
            pendingPlacedMarker := true
            pendingLabel := "Counter Pending"
        simPendingDirection := newPendingDirection
        simPendingKind := newPendingKind
        simPendingOrderType := newPendingOrderType
        simPendingEntry := newPendingEntry
        simPendingStop := newPendingStop
        simPendingTakeProfit := newPendingTakeProfit
        cycleAction := pendingLabel
    else if trendValid and not regimeConsumed
        newPendingDirection = trendDirection
        newPendingKind = "trend"
        newPendingOrderType = trendOrderType
        newPendingEntry = trendEntry
        newPendingStop = trendStop
        newPendingTakeProfit = trendTakeProfit
        regimeConsumed := true
        if sameTrendPendingType and (simPendingEntry != newPendingEntry or simPendingStop != newPendingStop or simPendingTakeProfit != newPendingTakeProfit)
            pendingRefreshedMarker := true
            pendingLabel := "Trend Refresh"
        else if simPendingDirection == 0 or not sameTrendPendingType
            pendingPlacedMarker := true
            pendingLabel := "Trend Pending"
        simPendingDirection := newPendingDirection
        simPendingKind := newPendingKind
        simPendingOrderType := newPendingOrderType
        simPendingEntry := newPendingEntry
        simPendingStop := newPendingStop
        simPendingTakeProfit := newPendingTakeProfit
        cycleAction := pendingLabel
    else
        if simPendingDirection != 0
            pendingCancelledMarker := true
            pendingLabel := simPendingKind == "trend" ? "Trend Cancel" : "Counter Cancel"
            cycleAction := pendingLabel
        simPendingDirection := 0
        simPendingKind := "none"
        simPendingOrderType := "none"
        simPendingEntry := na
        simPendingStop := na
        simPendingTakeProfit := na

activeTradeState = simActiveDirection == 1 ? (simActiveKind == "trend" ? "trend long active" : "counter long active") : simActiveDirection == -1 ? (simActiveKind == "trend" ? "trend short active" : "counter short active") : "flat"
pendingTradeState = simPendingDirection == 1 ? (simPendingKind == "trend" ? "trend pending long" : "counter pending long") : simPendingDirection == -1 ? (simPendingKind == "trend" ? "trend pending short" : "counter pending short") : "none"

regimeColor = regimeBullish ? color.new(color.green, 88) : regimeBearish ? color.new(color.red, 88) : color.new(color.gray, 92)
bgcolor(showRegimeBackground ? regimeColor : na)

bbUpperPlot = plot(bbUpper, "BB Upper", color=color.new(color.blue, 0), linewidth=1, display=display.all)
bbMiddlePlot = plot(bbMiddle, "BB Middle", color=color.new(color.orange, 0), linewidth=1, display=display.all)
bbLowerPlot = plot(bbLower, "BB Lower", color=color.new(color.blue, 0), linewidth=1, display=display.all)
fill(bbUpperPlot, bbLowerPlot, color=color.new(color.blue, 92), title="BB Fill")

barcolor(colorBarsByRegime ? regimeBullish ? color.new(color.lime, 0) : regimeBearish ? color.new(color.red, 0) : color.new(color.gray, 40) : na)

plotshape(showSignalMarkers and trendValid and trendDirection == 1, title="Trend Signal Long", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="Trend Sig")
plotshape(showSignalMarkers and trendValid and trendDirection == -1, title="Trend Signal Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="Trend Sig")
plotshape(showSignalMarkers and countertrendValid and countertrendDirection == 1, title="Countertrend Signal Long", style=shape.circle, location=location.belowbar, color=color.new(color.aqua, 0), size=size.small, text="Counter Sig")
plotshape(showSignalMarkers and countertrendValid and countertrendDirection == -1, title="Countertrend Signal Short", style=shape.circle, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.small, text="Counter Sig")
plotshape(showSweetSpotMarkers and closeInOuterBandSweetSpot and not closeDeepOutsideBands and regimeBullish, title="Bullish Sweet Spot", style=shape.diamond, location=location.abovebar, color=color.new(color.yellow, 0), size=size.tiny, text="Sweet")
plotshape(showSweetSpotMarkers and closeInOuterBandSweetSpot and not closeDeepOutsideBands and regimeBearish, title="Bearish Sweet Spot", style=shape.diamond, location=location.belowbar, color=color.new(color.yellow, 0), size=size.tiny, text="Sweet")
plotshape(showPendingMarkers and pendingPlacedMarker and simPendingKind == "trend" and simPendingDirection == 1, title="Trend Pending Long", style=shape.labelup, location=location.belowbar, color=color.new(color.silver, 0), text="Trend Pend")
plotshape(showPendingMarkers and pendingPlacedMarker and simPendingKind == "trend" and simPendingDirection == -1, title="Trend Pending Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.silver, 0), text="Trend Pend")
plotshape(showPendingMarkers and pendingPlacedMarker and simPendingKind == "countertrend" and simPendingDirection == 1, title="Counter Pending Long", style=shape.labelup, location=location.belowbar, color=color.new(color.silver, 0), text="Counter Pend")
plotshape(showPendingMarkers and pendingPlacedMarker and simPendingKind == "countertrend" and simPendingDirection == -1, title="Counter Pending Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.silver, 0), text="Counter Pend")
plotshape(showPendingMarkers and pendingRefreshedMarker and simPendingKind == "trend" and simPendingDirection == 1, title="Trend Refresh Long", style=shape.labelup, location=location.belowbar, color=color.new(color.gray, 0), text="Trend Refr")
plotshape(showPendingMarkers and pendingRefreshedMarker and simPendingKind == "trend" and simPendingDirection == -1, title="Trend Refresh Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.gray, 0), text="Trend Refr")
plotshape(showPendingMarkers and pendingRefreshedMarker and simPendingKind == "countertrend" and simPendingDirection == 1, title="Counter Refresh Long", style=shape.labelup, location=location.belowbar, color=color.new(color.gray, 0), text="Counter Refr")
plotshape(showPendingMarkers and pendingRefreshedMarker and simPendingKind == "countertrend" and simPendingDirection == -1, title="Counter Refresh Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.gray, 0), text="Counter Refr")
plotshape(showPendingMarkers and pendingCancelledMarker and regimeBullish, title="Pending Cancel Bullish", style=shape.xcross, location=location.abovebar, color=color.new(color.gray, 0), size=size.tiny, text="Cancel")
plotshape(showPendingMarkers and pendingCancelledMarker and regimeBearish, title="Pending Cancel Bearish", style=shape.xcross, location=location.belowbar, color=color.new(color.gray, 0), size=size.tiny, text="Cancel")
plotshape(showFillMarkers and fillMarker and filledPendingKind == "trend" and filledPendingDirection == 1, title="Trend Fill Long", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="Trend Fill")
plotshape(showFillMarkers and fillMarker and filledPendingKind == "trend" and filledPendingDirection == -1, title="Trend Fill Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="Trend Fill")
plotshape(showFillMarkers and fillMarker and filledPendingKind == "countertrend" and filledPendingDirection == 1, title="Counter Fill Long", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="Counter Fill")
plotshape(showFillMarkers and fillMarker and filledPendingKind == "countertrend" and filledPendingDirection == -1, title="Counter Fill Short", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="Counter Fill")
plotshape(showTradeManagementMarkers and stopAdjustMarker and simActiveDirection == 1, title="Adjust Stop Long", style=shape.labeldown, location=location.abovebar, color=color.new(color.orange, 0), text="Stop Adj")
plotshape(showTradeManagementMarkers and stopAdjustMarker and simActiveDirection == -1, title="Adjust Stop Short", style=shape.labelup, location=location.belowbar, color=color.new(color.orange, 0), text="Stop Adj")
plotshape(showTradeManagementMarkers and tpAdjustMarker and simActiveDirection == 1, title="Adjust TP Long", style=shape.labeldown, location=location.abovebar, color=color.new(color.navy, 0), text="TP Adj")
plotshape(showTradeManagementMarkers and tpAdjustMarker and simActiveDirection == -1, title="Adjust TP Short", style=shape.labelup, location=location.belowbar, color=color.new(color.navy, 0), text="TP Adj")
plotshape(showTradeManagementMarkers and exitMarker and exitLabel == "Trend Exit" and regimeBullish, title="Trend Exit Bullish", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="Trend Exit")
plotshape(showTradeManagementMarkers and exitMarker and exitLabel == "Trend Exit" and regimeBearish, title="Trend Exit Bearish", style=shape.labelup, location=location.belowbar, color=color.new(color.red, 0), text="Trend Exit")
plotshape(showTradeManagementMarkers and exitMarker and exitLabel == "Counter Exit" and regimeBullish, title="Counter Exit Bullish", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="Counter Exit")
plotshape(showTradeManagementMarkers and exitMarker and exitLabel == "Counter Exit" and regimeBearish, title="Counter Exit Bearish", style=shape.labelup, location=location.belowbar, color=color.new(color.red, 0), text="Counter Exit")
plotshape(showSignalMarkers and barsSinceRegimeStart == 1, title="Regime Start", style=shape.square, location=location.bottom, color=regimeBullish ? color.new(color.green, 0) : regimeBearish ? color.new(color.red, 0) : color.new(color.gray, 0), size=size.tiny, text="R1")

plot(showSignalLevels and simPendingDirection != 0 ? simPendingEntry : na, "Pending Entry", color=color.new(color.gray, 0), style=plot.style_linebr, linewidth=2)
plot(showSignalLevels and simPendingDirection != 0 ? simPendingStop : na, "Pending Stop", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=1)
plot(showSignalLevels and simPendingDirection != 0 ? simPendingTakeProfit : na, "Pending Take Profit", color=color.new(color.blue, 20), style=plot.style_linebr, linewidth=1)
plot(showSignalLevels and simActiveDirection != 0 ? simActiveEntry : na, "Active Entry", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(showSignalLevels and simActiveDirection != 0 ? simActiveStop : na, "Active Stop", color=color.new(color.orange, 0), style=plot.style_linebr, linewidth=2)
plot(showSignalLevels and simActiveDirection != 0 ? simActiveTakeProfit : na, "Active Take Profit", color=color.new(color.teal, 0), style=plot.style_linebr, linewidth=2)

var table statusTable = table.new(position.top_right, 2, 18, border_width=1)
if barstate.islast and showStatusTable
    table.cell(statusTable, 0, 0, "Regime", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 0, regimeName, text_color=color.white, bgcolor=regimeBullish ? color.green : regimeBearish ? color.red : color.gray)
    table.cell(statusTable, 0, 1, "Bars Since Regime Start", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 1, str.tostring(barsSinceRegimeStart), text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 2, "MACD / Signal", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 2, str.format("{0} / {1}", str.tostring(macdLine, format.mintick), str.tostring(macdSignalLine, format.mintick)), text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 3, "Bandwidth OK", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 3, hasSufficientBandwidth ? "yes" : "no", text_color=color.white, bgcolor=hasSufficientBandwidth ? color.green : color.red)
    table.cell(statusTable, 0, 4, "Trend Half OK", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 4, closeInRelevantBandHalf ? "yes" : "no", text_color=color.white, bgcolor=closeInRelevantBandHalf ? color.green : color.red)
    table.cell(statusTable, 0, 5, "Trend Signal", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 5, trendValid ? trendSignalType : trendReason, text_color=color.white, bgcolor=trendValid ? color.green : color.gray)
    table.cell(statusTable, 0, 6, "Counter Signal", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 6, countertrendValid ? countertrendSignalType : countertrendReason, text_color=color.white, bgcolor=countertrendValid ? color.orange : color.gray)
    table.cell(statusTable, 0, 7, "Outside Trigger", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 7, outsideTriggerReason, text_color=color.white, bgcolor=closeOutsideTrigger ? color.orange : color.gray)
    table.cell(statusTable, 0, 8, "Regime Consumed", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 8, regimeConsumed ? "yes" : "no", text_color=color.white, bgcolor=regimeConsumed ? color.orange : color.gray)
    table.cell(statusTable, 0, 9, "Pending State", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 9, pendingTradeState, text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 10, "Active State", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 10, activeTradeState, text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 11, "Cycle Action", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 11, cycleAction, text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 12, "BB Upper / Middle / Lower", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 12, str.format("{0} / {1} / {2}", str.tostring(bbUpper, format.mintick), str.tostring(bbMiddle, format.mintick), str.tostring(bbLower, format.mintick)), text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 13, "Pending Entry / SL / TP", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 13, simPendingDirection != 0 ? str.format("{0} / {1} / {2}", str.tostring(simPendingEntry, format.mintick), str.tostring(simPendingStop, format.mintick), str.tostring(simPendingTakeProfit, format.mintick)) : "n/a", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 14, "Active Entry / SL / TP", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 14, simActiveDirection != 0 ? str.format("{0} / {1} / {2}", str.tostring(simActiveEntry, format.mintick), str.tostring(simActiveStop, format.mintick), str.tostring(simActiveTakeProfit, format.mintick)) : "n/a", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 0, 15, "Trend Exit Trigger", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 15, activeTrendTrade and closeOutsideTrigger ? "yes" : "no", text_color=color.white, bgcolor=activeTrendTrade and closeOutsideTrigger ? color.orange : color.gray)
    table.cell(statusTable, 0, 16, "Counter Exit Trigger", text_color=color.white, bgcolor=color.black)
    counterExitNow = activeCountertrendTrade and (simActiveDirection == 1 ? high >= bbMiddle : low <= bbMiddle)
    table.cell(statusTable, 1, 16, counterExitNow ? "yes" : "no", text_color=color.white, bgcolor=counterExitNow ? color.orange : color.gray)
    table.cell(statusTable, 0, 17, "Buy Spread", text_color=color.white, bgcolor=color.black)
    table.cell(statusTable, 1, 17, str.tostring(buySpread, format.mintick), text_color=color.white, bgcolor=color.black)
