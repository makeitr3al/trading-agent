# --- Propr environment ---
# beta is the safe default for development and testing.
PROPR_ENV=beta

PROPR_BETA_API_KEY=
PROPR_BETA_API_URL=https://api.beta.propr.xyz/v1
PROPR_BETA_WS_URL=wss://api.beta.propr.xyz/ws

# prod must only be enabled deliberately.
PROPR_PROD_API_KEY=
PROPR_PROD_API_URL=https://api.propr.xyz/v1
PROPR_PROD_WS_URL=wss://api.propr.xyz/ws
PROPR_PROD_CONFIRM=NO

# --- Shared defaults ---
PROPR_SYMBOL=BTC/USDC
PROPR_REQUIRE_HEALTHY_CORE=YES
PROPR_LEVERAGE=1
# optional override; default is environment-specific
# TRADING_JOURNAL_PATH=artifacts/trading_journal_beta.jsonl
# RUNNER_STATUS_PATH=artifacts/runner_status_beta.json
# TRADING_AGENT_RUNTIME_CONFIG_PATH=artifacts/runtime_overrides.json

# --- Hyperliquid historical market data ---
# HYPERLIQUID_COIN is the perp coin name, for example BTC or ETH.
# It is not the execution symbol like BTC/USDC.
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_COIN=BTC
HYPERLIQUID_INTERVAL=1d
HYPERLIQUID_LOOKBACK_BARS=200

# --- Data source selection ---
# live = Hyperliquid historical candles
# golden = one explicit strategy golden scenario for validation only
DATA_SOURCE=live
GOLDEN_SCENARIO=

# --- Manual scripts ---
MANUAL_WRITE_CONFIRM=NO
MANUAL_ORDER_TYPES_CONFIRM=NO
MANUAL_LIVE_CYCLE_CONFIRM=NO
MANUAL_ALLOW_SUBMIT=NO

# --- Scheduled runner ---
RUNNER_CONFIRM=NO
RUNNER_ALLOW_SUBMIT=NO
# RUNNER_MODE:
# daily = once per UTC day at RUNNER_TIME_UTC
# interval = every RUNNER_INTERVAL_SECONDS
# manual = run exactly once immediately and exit
RUNNER_MODE=manual
RUNNER_TIME_UTC=07:00
RUNNER_INTERVAL_SECONDS=60

# --- Multi-market scan ---
# Prefer SCAN_MARKETS with SYMBOL:COIN pairs.
# SCAN_SYMBOLS and SCAN_HYPERLIQUID_COINS remain as a legacy fallback.
SCAN_CONFIRM=NO
SCAN_MARKETS=BTC/USDC:BTC,ETH/USDC:ETH,SOL/USDC:SOL
SCAN_SYMBOLS=BTC/USDC,ETH/USDC,SOL/USDC
SCAN_HYPERLIQUID_COINS=BTC,ETH,SOL
SCAN_ALLOW_SUBMIT=NO
