# --- Propr environment ---
# beta is the safe default for development and testing.
PROPR_ENV=beta

PROPR_BETA_API_KEY=
PROPR_BETA_API_URL=https://api.beta.propr.xyz/v1
PROPR_BETA_WS_URL=wss://api.beta.propr.xyz/ws

# prod must only be enabled deliberately.
PROPR_PROD_API_KEY=
PROPR_PROD_API_URL=https://api.propr.xyz/v1
PROPR_PROD_WS_URL=wss://api.propr.xyz/ws
PROPR_PROD_CONFIRM=NO

# --- Shared defaults ---
PROPR_SYMBOL=BTC/USDC
PROPR_REQUIRE_HEALTHY_CORE=YES

# --- Data source selection ---
# live = live/stub market data path
# golden = one explicit strategy golden scenario for validation only
DATA_SOURCE=live
GOLDEN_SCENARIO=

# --- Manual test switches ---
MANUAL_WRITE_CONFIRM=NO
MANUAL_LIVE_CYCLE_CONFIRM=NO
MANUAL_ALLOW_SUBMIT=NO

# --- Scheduled runner ---
RUNNER_CONFIRM=NO
RUNNER_ALLOW_SUBMIT=NO
RUNNER_MODE=daily
RUNNER_TIME_UTC=07:00
RUNNER_INTERVAL_SECONDS=60
